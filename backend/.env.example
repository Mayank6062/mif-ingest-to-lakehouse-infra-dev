# ─────────────────────────────────────────────────────────────────────────────
# MIF Glue Job Agent — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it contains live secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Azure OpenAI via EPAM proxy (or direct Azure OpenAI endpoint)
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_ENDPOINT=https://ai-proxy.lab.epam.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# GitHub integration
# Token requires 'repo' scope on the target repository.
# For production, prefer a GitHub App with minimal permissions.
GITHUB_TOKEN=<your-github-personal-access-token>
GITHUB_REPO_OWNER=<github-org-or-username>
GITHUB_REPO_NAME=mif-ingest-to-lakehouse-infra-dev
GITHUB_BASE_BRANCH=main

# Optional: comma-separated GitHub usernames to assign as PR reviewers.
# Leave blank to skip reviewer assignment.
GITHUB_PR_REVIEWERS=

# App settings
KNOWLEDGE_BASE_PATH=./knowledge_base
SESSION_STORE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000

# Checkpointer mode
# Set USE_REDIS_CHECKPOINTER=false (default) to use in-memory state — no Redis required.
# Set USE_REDIS_CHECKPOINTER=true  to enable STEP 20 Redis persistence (production).
USE_REDIS_CHECKPOINTER=false

# ─────────────────────────────────────────────────────────────────────────────
# LangSmith Observability (optional)
#
# Tracing is disabled by default. Enable only when you have a valid LangSmith
# API key. When disabled, no environment variables are injected and no traces
# are sent to LangSmith.
#
# To enable:
#   1. Set LANGSMITH_TRACING_V2=true
#   2. Set LANGSMITH_API_KEY to your LangSmith API key
#   3. Optionally set LANGSMITH_PROJECT to a project name
# ─────────────────────────────────────────────────────────────────────────────
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=glue-job-agent
