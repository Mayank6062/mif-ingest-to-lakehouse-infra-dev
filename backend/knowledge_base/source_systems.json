  "new_source_system_creation_checklist": [
    "1. Verify source system does NOT already exist as a folder",
    "2. Create folder: {source_system}/ at repository root",
    "3. Create locals.tf inside the folder with: ent_func, subgroup, kafka_bootstrap_endpoint map, schema_registry_endpoint map, miw_account_id map, glue_jobs map",
    "4. Create glue.tf inside the folder with: module reference to modules/glue_job, for_each = local.glue_jobs",
    "5. Add the new folder path to .vela.py for CI/CD deployment",
    "6. Add first job entry to glue_jobs map in locals.tf"
  ],

  "decision_tree": {
    "question": "Does the source system folder already exist?",
    "yes": {
      "action": "Add new job entry to existing locals.tf → glue_jobs map",
      "files_modified": ["{source_system}/locals.tf"],
      "files_created": []
    },
    "no": {
      "action": "Create new source system folder with locals.tf and glue.tf",
      "files_modified": [".vela.py"],
      "files_created": [
        "{source_system}/locals.tf",
        "{source_system}/glue.tf"
      ]
    }
  }
