      "description": "Uses locals.tf + glue.tf with local modules/glue_job module",
      "files": ["locals.tf", "glue.tf"],
      "update_strategy": "Add new entry to glue_jobs map in locals.tf only"
    },
    "external_module": {
      "description": "Uses locals.tf + main.tf with external Talaria minerva-talaria-terraform-modules",
      "files": ["locals.tf", "main.tf"],
      "update_strategy": "Modify locals.tf configuration; main.tf handles module wiring"
    },
    "specialized": {
      "description": "Edge cases: ECS, testing, or utility stacks",
      "files": ["varies"],
      "update_strategy": "Requires manual review"
    }
  },

